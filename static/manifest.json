{
  "name": "envoy",
  "short_name": "envoy",
  "description": "Web-based terminal emulator",
  "start_url": "/envoy/",
  "display": "standalone",
  "launch_handler": {
    "client_mode": "navigate-new"
  },
  "background_color": "#000000",
  "theme_color": "#000000",
  "icons": [
    {
      "src": "/envoy/static/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/envoy/static/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/envoy/static/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/envoy/static/icon-192-maskable.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/envoy/static/icon-512-maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ]
}
